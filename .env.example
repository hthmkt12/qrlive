VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Optional: seeded dashboard account for Playwright E2E.
# Recommended convention:
#   E2E_TEST_EMAIL=qrlive.e2e@example.com
# Create that user once in Supabase Auth, then keep the password only in local/CI env.
E2E_TEST_EMAIL=qrlive.e2e@example.com
E2E_TEST_PASSWORD=change-me-in-.env.local

# Optional: custom redirect domain for China/firewall accessibility.
# Leave empty to use Supabase Edge Function URL (default).
# Example: https://r.yourdomain.com
VITE_REDIRECT_BASE_URL=
